DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Chave genérica — usada como fallback se as específicas abaixo não forem definidas
GEMINI_API_KEY=coloque-sua-chave-aqui

# Chaves por função (opcional, mas recomendado para distribuir cota)
# Se não definidas, todas as funções usam GEMINI_API_KEY
GEMINI_API_KEY_CONVERTER=
GEMINI_API_KEY_VALIDATOR=
GEMINI_API_KEY_RECONVERTER=

GEMINI_MODEL=gemini-3.1-flash-lite
PDF_BLOCK_SIZE=5
